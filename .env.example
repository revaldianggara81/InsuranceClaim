# ── Oracle Database ─────────────────────────────────────────
ORACLE_BRONZE_HOST=localhost
ORACLE_BRONZE_PORT=1521
ORACLE_BRONZE_SERVICE=FREEPDB1
ORACLE_BRONZE_USER=claims_bronze
ORACLE_BRONZE_PASSWORD=claims_bronze

ORACLE_SILVER_USER=claims_silver
ORACLE_SILVER_PASSWORD=claims_silver

ORACLE_GOLD_USER=claims_gold
ORACLE_GOLD_PASSWORD=claims_gold

# ── Oracle DB Admin Password (used in Dockerfile & docker-compose) ───────────
ORACLE_PWD=<your-password>

# ── Roving Edge Device (RED) Object Storage ──────────────────
RED_STORAGE_BASE_URL=https://red2-mysatellite-red-1:8015/object-storage/buckets/rover-namespace/<your-bucket>
RED_USERNAME=
RED_PASSWORD=
OCI_EVIDENCE_PREFIX=Evidance

# ── Knowledge Base (PDF Policy Document) ─────────────────────
KB_LOCAL_PATH=/app/knowledge_base
KB_PDF_PAR_URL=

# ── Ollama — LLM & VLM Backend ──────────────────────────────
